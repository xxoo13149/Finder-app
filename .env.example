# Local secrets for development only.
# Copy this file to .env and fill in real values.

ETHERSCAN_API_KEY=replace_me
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=45

# SmartPro online admin import target.
# Use the same secret value as the Cloudflare FINDER_SYNC_TOKEN binding.
SMART_PRO_BASE_URL=https://your-smartpro-domain.example
SMART_PRO_FINDER_TOKEN=replace_me
SMART_PRO_ACCESS_CLIENT_ID=
SMART_PRO_ACCESS_CLIENT_SECRET=

# Cloudflare D1 cloud persistence.
CLOUDFLARE_ACCOUNT_ID=replace_me
CLOUDFLARE_D1_DATABASE_ID=replace_me
# Preferred when you create a scoped Cloudflare API token.
CLOUDFLARE_API_TOKEN=replace_me
# Alternative for Cloudflare Global API Key authentication.
CLOUDFLARE_EMAIL=replace_me
CLOUDFLARE_GLOBAL_API_KEY=replace_me
